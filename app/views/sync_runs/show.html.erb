<% content_for :title, "Sync run" %>

<%= turbo_stream_from @sync_run %>

<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-mono text-sm text-slate-500">Sync run #<%= @sync_run.id %></p>
      <h1 class="mt-1 text-3xl font-semibold text-slate-950">Bulk sync</h1>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "All sync runs", sync_runs_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
      <%= button_to "Sync all", sync_runs_path, class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
    </div>
  </div>

  <%= render @sync_run %>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 px-4 py-3">
      <h2 class="text-base font-semibold text-slate-950">Assignments</h2>
    </div>

    <% if @sync_run_items.any? %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
          <tr>
            <th class="px-4 py-3">Indexer</th>
            <th class="px-4 py-3">App</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Started</th>
            <th class="px-4 py-3">Finished</th>
            <th class="px-4 py-3">Error</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <%= render @sync_run_items %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm font-medium text-slate-700">No enabled assignments were available to sync.</p>
      </div>
    <% end %>
  </section>
</div>
