<tr id="<%= dom_id(sync_run_item) %>">
  <td class="px-4 py-3 font-medium text-slate-950">
    <% if sync_run_item.indexer.present? %>
      <%= link_to sync_run_item.indexer_label, sync_run_item.indexer, class: "hover:underline" %>
    <% else %>
      <%= sync_run_item.indexer_label %>
    <% end %>
  </td>
  <td class="px-4 py-3 text-slate-700">
    <% if sync_run_item.arr_app.present? %>
      <%= link_to sync_run_item.arr_app_label, sync_run_item.arr_app, class: "hover:underline" %>
    <% else %>
      <%= sync_run_item.arr_app_label %>
    <% end %>
  </td>
  <td class="px-4 py-3">
    <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", sync_run_status_classes(sync_run_item.status)) %>">
      <%= sync_run_status_label(sync_run_item.status) %>
    </span>
  </td>
  <td class="px-4 py-3 text-slate-700"><%= sync_run_item.started_at.present? ? format_server_timestamp(sync_run_item.started_at) : "Not started" %></td>
  <td class="px-4 py-3 text-slate-700"><%= sync_run_item.finished_at.present? ? format_server_timestamp(sync_run_item.finished_at) : "Not finished" %></td>
  <td class="<%= class_names("max-w-xl px-4 py-3 align-top", sync_run_item.failed? ? "text-red-800" : "text-slate-700") %>">
    <% if sync_run_item.error.present? %>
      <% if sync_run_item.error_kind.present? %>
        <p class="mb-1 text-xs font-semibold uppercase tracking-normal text-slate-500"><%= sync_error_kind_label(sync_run_item.error_kind) %></p>
      <% end %>
      <p class="whitespace-pre-wrap break-words text-sm leading-6"><%= sync_run_item.error %></p>
    <% else %>
      None
    <% end %>
  </td>
</tr>
