<section id="<%= dom_id(sync_run) %>" class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
  <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="text-base font-semibold text-slate-950">Run summary</h2>
    <% unless sync_run.complete? %>
      <%= button_to "Abandon run", abandon_sync_run_path(sync_run), class: "inline-flex w-fit items-center justify-center rounded-md border border-red-200 bg-white px-3 py-2 text-xs font-semibold text-red-700 hover:bg-red-50", data: { turbo_confirm: "Mark this unfinished sync run as failed?" } %>
    <% end %>
  </div>

  <div class="grid gap-px bg-slate-200 sm:grid-cols-2 lg:grid-cols-7">
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Status</p>
      <p class="mt-2">
        <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", sync_run_status_classes(sync_run.status)) %>">
          <%= sync_run_status_label(sync_run.status) %>
        </span>
      </p>
    </div>
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Assignments</p>
      <p class="mt-2 text-2xl font-semibold text-slate-950"><%= sync_run.total_count %></p>
    </div>
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Succeeded</p>
      <p class="mt-2 text-2xl font-semibold text-slate-950"><%= sync_run.success_count %></p>
    </div>
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Failed</p>
      <p class="mt-2 text-2xl font-semibold text-slate-950"><%= sync_run.failure_count %></p>
    </div>
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Mismatches</p>
      <p class="mt-2 text-2xl font-semibold text-slate-950"><%= sync_run.mismatch_count %></p>
    </div>
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Skipped</p>
      <p class="mt-2 text-2xl font-semibold text-slate-950"><%= sync_run.skipped_count %></p>
    </div>
    <div class="bg-white px-4 py-4">
      <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Started</p>
      <p class="mt-2 text-sm font-semibold text-slate-700"><%= sync_run.started_at.present? ? format_server_timestamp(sync_run.started_at) : "Queued" %></p>
    </div>
  </div>

  <% if sync_run.error.present? %>
    <div class="break-words border-t border-red-100 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">
      <%= sync_run.error %>
    </div>
  <% end %>
</section>
