<% content_for :title, "Settings" %>

<div class="space-y-8">
  <div>
    <h1 class="text-3xl font-semibold text-slate-950">Settings</h1>
    <p class="mt-2 max-w-4xl text-sm leading-6 text-slate-600">
      Connect Bridgarr to the Jackett instance that owns your indexer configuration. Bridgarr uses these settings to discover indexers, sync apps directly to Jackett by default, and bridge selected assignments through Bridgarr when you want proxy visibility.
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <%= form_with url: settings_path, method: :patch, scope: :settings, class: "space-y-6 rounded-md border border-stone-200 bg-white p-6 shadow-sm lg:col-span-2" do |form| %>
      <div>
        <h2 class="text-xl font-semibold text-slate-950">Connection settings</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Save the Jackett connection Bridgarr should use behind the scenes. The Bridgarr URL is only required for assignments set to bridged mode.
        </p>
      </div>

      <div>
        <%= form.label :bridgarr_base_url, "Bridgarr URL", class: "block text-sm font-medium text-slate-700" %>
        <%= form.url_field :bridgarr_base_url, value: @bridgarr_base_url, placeholder: "http://localhost:3000", class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        <p class="mt-2 text-xs leading-5 text-slate-500">
          Use a URL your Sonarr, Radarr, Lidarr, and other apps can reach. Bridged assignments point here; direct assignments point apps at Jackett.
        </p>
      </div>

      <div>
        <%= form.label :jackett_base_url, "Jackett URL", class: "block text-sm font-medium text-slate-700" %>
        <%= form.url_field :jackett_base_url, value: @jackett_base_url, placeholder: "http://localhost:9117", class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
      </div>

      <div>
        <%= form.label :jackett_api_key, "Jackett API key", class: "block text-sm font-medium text-slate-700" %>
        <%= form.password_field :jackett_api_key, value: @jackett_api_key, class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
      </div>

      <div class="flex justify-end">
        <%= form.submit "Save settings", class: "rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      </div>
    <% end %>

    <section class="space-y-4 rounded-md border border-stone-200 bg-white p-6 shadow-sm">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-950">Jackett connection</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Test the saved Jackett URL and API key Bridgarr uses for discovery, app sync, and bridged proxy requests.
        </p>

        <%= button_to "Test Jackett", test_jackett_settings_path, class: "w-full rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      </div>

      <div class="rounded-md border border-stone-200 bg-stone-50 p-4">
        <% if @jackett_last_status.present? %>
          <div class="space-y-3">
            <span class="inline-flex rounded-md px-2 py-1 text-xs font-semibold uppercase <%= @jackett_last_status == "ok" ? "bg-amber-50 text-amber-900" : "bg-red-50 text-red-800" %>">
              <%= @jackett_last_status == "ok" ? "Connected" : "Failed" %>
            </span>

            <% if @jackett_last_tested_at.present? %>
              <p class="text-sm leading-6 text-slate-600">Last tested <%= format_server_timestamp(@jackett_last_tested_at) %></p>
            <% end %>
          </div>

          <% if @jackett_last_error.present? %>
            <p class="mt-3 text-sm leading-6 text-red-800"><%= @jackett_last_error %></p>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-600">Jackett has not been tested yet.</p>
        <% end %>
      </div>
    </section>

    <section class="rounded-md border border-stone-200 bg-white p-6 shadow-sm lg:col-start-3">
      <h2 class="text-xl font-semibold text-slate-950">Build info</h2>
      <dl class="mt-4 space-y-3 text-sm">
        <div>
          <dt class="font-medium text-slate-500">Version</dt>
          <dd class="mt-1 font-mono text-slate-900"><%= @build_info.version %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-500">Commit</dt>
          <dd class="mt-1 font-mono text-slate-900"><%= @build_info.short_commit_sha %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-500">Build date</dt>
          <dd class="mt-1 font-mono text-slate-900"><%= @build_info.build_date %></dd>
        </div>
      </dl>
    </section>
  </div>
</div>
