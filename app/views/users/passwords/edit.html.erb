<% content_for :title, "Choose a new password" %>

<div class="mx-auto max-w-md">
  <section class="rounded-md border border-stone-200 bg-white p-6 shadow-sm sm:p-8">
    <h1 class="text-3xl font-semibold text-slate-950">Choose a new password</h1>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |form| %>
      <%= render "users/shared/error_messages", resource: resource %>
      <%= form.hidden_field :reset_password_token %>

      <div>
        <%= form.label :password, "New password", class: "block text-sm font-medium text-slate-700" %>
        <%= form.password_field :password, autofocus: true, autocomplete: "new-password", required: true, minlength: @minimum_password_length, class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        <p class="mt-2 text-xs text-slate-500">Use at least <%= @minimum_password_length %> characters.</p>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-slate-700" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
      </div>

      <%= form.submit "Change password", class: "w-full rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
    <% end %>

    <%= render "users/shared/links" %>
  </section>
</div>
