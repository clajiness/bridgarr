<div id="<%= dom_id indexer %>" class="rounded-md border border-stone-200 bg-white shadow-sm">
  <dl class="divide-y divide-slate-200 text-sm">
    <div class="grid gap-1 px-4 py-3 sm:grid-cols-3">
      <dt class="font-medium text-slate-500">Enabled</dt>
      <dd class="sm:col-span-2"><%= indexer.enabled? ? "Yes" : "No" %></dd>
    </div>
    <div class="grid gap-1 px-4 py-3 sm:grid-cols-3">
      <dt class="font-medium text-slate-500">Assigned apps</dt>
      <dd class="sm:col-span-2"><%= indexer.arr_apps.map(&:name).to_sentence.presence || "None" %></dd>
    </div>
    <div class="grid gap-1 px-4 py-3 sm:grid-cols-3">
      <dt class="font-medium text-slate-500">Last status</dt>
      <dd class="sm:col-span-2"><%= indexer.last_status.presence || "Not tested" %></dd>
    </div>
    <div class="grid gap-1 px-4 py-3 sm:grid-cols-3">
      <dt class="font-medium text-slate-500">Last error</dt>
      <dd class="sm:col-span-2"><%= indexer.last_error.presence || "None" %></dd>
    </div>
  </dl>
</div>
