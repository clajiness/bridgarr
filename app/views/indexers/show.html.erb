<% content_for :title, "Showing indexer" %>

<div class="max-w-4xl space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-mono text-sm text-slate-500"><%= @indexer.jackett_id %></p>
      <h1 class="mt-1 text-3xl font-semibold text-slate-950"><%= @indexer.name %></h1>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Edit", edit_indexer_path(@indexer), class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      <%= link_to "Back", indexers_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
    </div>
  </div>

  <%= render @indexer %>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Proxy activity</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          <%= @proxy_activity_filter == "failed" ? "Showing recent failed proxy requests with error details." : "Showing recent proxy requests." %>
        </p>
      </div>

      <div class="inline-flex w-fit rounded-md border border-stone-200 bg-stone-50 p-1">
        <%= link_to "Recent", indexer_path(@indexer), class: class_names("rounded px-3 py-1.5 text-xs font-semibold", @proxy_activity_filter == "recent" ? "bg-white text-slate-950 shadow-sm" : "text-slate-600 hover:text-slate-950") %>
        <%= link_to "Failures", indexer_path(@indexer, proxy_activity: "failed"), class: class_names("rounded px-3 py-1.5 text-xs font-semibold", @proxy_activity_filter == "failed" ? "bg-white text-slate-950 shadow-sm" : "text-slate-600 hover:text-slate-950") %>
      </div>
    </div>

    <div class="grid gap-px bg-slate-200 sm:grid-cols-2 lg:grid-cols-5">
      <div class="bg-white px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Last 24h</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:total] %></p>
      </div>
      <div class="bg-white px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Successful</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:successful] %></p>
      </div>
      <div class="bg-white px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Failed</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:failed] %></p>
      </div>
      <div class="bg-white px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Downloads</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:downloads] %></p>
      </div>
      <div class="bg-white px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Avg duration</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= proxy_duration(@proxy_activity_stats[:average_duration_ms]) %></p>
      </div>
    </div>

    <% if @proxy_requests.any? %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
          <tr>
            <th class="px-4 py-3">When</th>
            <th class="px-4 py-3">Type</th>
            <th class="px-4 py-3">Query</th>
            <th class="px-4 py-3">Categories</th>
            <th class="px-4 py-3">Result</th>
            <th class="px-4 py-3">Duration</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @proxy_requests.each do |proxy_request| %>
            <tr>
              <td class="px-4 py-3 whitespace-nowrap text-xs text-slate-500"><%= format_server_timestamp(proxy_request.created_at) %></td>
              <td class="px-4 py-3">
                <span class="inline-flex rounded-md border border-stone-200 bg-stone-50 px-2 py-1 text-xs font-semibold text-slate-700">
                  <%= proxy_request_type_label(proxy_request.request_type) %>
                </span>
              </td>
              <td class="px-4 py-3 text-slate-700"><%= proxy_request.query.presence || "None" %></td>
              <td class="px-4 py-3 font-mono text-xs text-slate-600"><%= proxy_request.categories.presence || "None" %></td>
              <td class="px-4 py-3">
                <div class="space-y-2">
                  <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", proxy_request_status_classes(proxy_request)) %>">
                    <%= proxy_request_status_label(proxy_request) %>
                  </span>
                  <p class="text-xs text-slate-500">
                    HTTP <%= proxy_request.http_status.presence || "n/a" %> · <%= proxy_request_item_count(proxy_request) %>
                  </p>
                  <% if proxy_request.error.present? %>
                    <p class="max-w-xl text-xs leading-5 text-red-800"><%= proxy_request.error %></p>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-slate-700"><%= proxy_duration(proxy_request.duration_ms) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-sm font-medium text-slate-700">
          <%= @proxy_activity_filter == "failed" ? "No failed proxy requests recorded for this indexer." : "No proxy requests recorded yet." %>
        </p>
      </div>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 px-4 py-3">
      <h2 class="text-base font-semibold text-slate-950">App assignments</h2>
    </div>

    <% if @indexer.indexer_apps.any? %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
          <tr>
            <th class="px-4 py-3">App</th>
            <th class="px-4 py-3">Remote ID</th>
            <th class="px-4 py-3">Sync status</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @indexer.indexer_apps.includes(:arr_app).order("arr_apps.name").each do |assignment| %>
            <tr>
              <td class="px-4 py-3 font-medium text-slate-950"><%= link_to assignment.arr_app.name, assignment.arr_app, class: "hover:underline" %></td>
              <td class="px-4 py-3 font-mono text-xs text-slate-700"><%= assignment.remote_indexer_id.presence || "None" %></td>
              <td class="px-4 py-3">
                <% if assignment.last_status.present? %>
                  <div class="min-w-40 space-y-2">
                    <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", assignment_status_classes(assignment)) %>">
                      <%= assignment_status_label(assignment) %>
                    </span>
                    <% if assignment.last_synced_at.present? %>
                      <p class="text-xs leading-5 text-slate-500"><%= format_server_timestamp(assignment.last_synced_at) %></p>
                    <% end %>
                    <% if assignment.last_error.present? %>
                      <p class="<%= class_names("text-xs leading-5", assignment.last_status == "error" ? "text-red-800" : "text-slate-500") %>"><%= assignment.last_error %></p>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-slate-500">Pending sync</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex flex-wrap justify-end gap-2">
                  <%= link_to "Settings", edit_indexer_app_path(assignment), class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-stone-50" %>
                  <%= button_to "Sync", sync_indexer_app_path(assignment), class: "rounded-md border border-stone-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-stone-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm font-medium text-slate-700">Assign this indexer to an app before syncing.</p>
      </div>
    <% end %>
  </section>

  <div class="border-t border-slate-200 pt-6">
    <%= button_to "Remove indexer", @indexer, method: :delete, class: "rounded-md bg-red-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-600", data: { turbo_confirm: "Remove this Bridgarr indexer? Any synced copies in assigned apps will be removed too." } %>
  </div>
</div>
