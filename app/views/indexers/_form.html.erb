<%= form_with(model: indexer, class: "space-y-6 rounded-md border border-stone-200 bg-white p-6 shadow-sm") do |form| %>
  <% if indexer.errors.any? %>
    <div id="error_explanation" class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <p class="font-semibold"><%= pluralize(indexer.errors.count, "error") %> blocked this indexer from being saved.</p>

      <ul class="mt-2 list-disc pl-5">
        <% indexer.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :name, placeholder: "NZB Finder", class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
  </div>

  <div>
    <%= form.label :jackett_id, "Jackett Torznab URL or ID", class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :jackett_id, placeholder: "http://localhost:9117/api/v2.0/indexers/nzbfinder/results/torznab/", class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
    <p class="mt-2 text-xs leading-5 text-slate-500">
      Paste the Torznab feed URL from Jackett, or enter the indexer ID directly. Bridgarr stores only the indexer ID.
    </p>
  </div>

  <div class="flex items-center gap-3">
    <%= form.checkbox :enabled, class: "h-4 w-4 rounded border-stone-300 text-amber-600 focus:ring-amber-500" %>
    <%= form.label :enabled, class: "text-sm font-medium text-slate-700" %>
  </div>

  <fieldset class="space-y-3">
    <legend class="text-sm font-medium text-slate-700">Assigned apps</legend>
    <% if @arr_apps.any? %>
      <div class="grid gap-3 sm:grid-cols-2">
        <%= form.collection_check_boxes :arr_app_ids, @arr_apps, :id, :name do |builder| %>
          <label class="flex items-center gap-3 rounded-md border border-stone-200 px-3 py-2 text-sm text-slate-700 hover:border-amber-200 hover:bg-amber-50/40">
            <%= builder.check_box class: "h-4 w-4 rounded border-stone-300 text-amber-600 focus:ring-amber-500" %>
            <span><%= builder.text %></span>
          </label>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        <%= link_to "Add an app", new_arr_app_path, class: "font-semibold underline underline-offset-2 hover:text-amber-950" %>
        before assigning this indexer.
      </div>
    <% end %>
  </fieldset>

  <div class="flex flex-col-reverse gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:justify-end">
    <%= link_to "Cancel", indexers_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
    <%= form.submit "Save indexer", class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
  </div>
<% end %>
