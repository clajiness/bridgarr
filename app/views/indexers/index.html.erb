<% content_for :title, "Indexers" %>

<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-950">Indexers</h1>
      <p class="mt-2 text-sm leading-6 text-slate-600">Jackett indexer records and their app assignments.</p>
    </div>

    <%= link_to "New indexer", new_indexer_path, class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
  </div>

  <div class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <% if @indexers.any? %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Jackett ID</th>
            <th class="px-4 py-3">Apps</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @indexers.each do |indexer| %>
            <tr>
              <td class="px-4 py-3 font-medium text-slate-950"><%= link_to indexer.name, indexer, class: "hover:underline" %></td>
              <td class="px-4 py-3 font-mono text-xs text-slate-700"><%= indexer.jackett_id %></td>
              <td class="px-4 py-3 text-slate-700"><%= indexer.arr_apps.map(&:name).to_sentence.presence || "None" %></td>
              <td class="px-4 py-3">
                <span class="<%= class_names("rounded-md border px-2 py-1 text-xs font-semibold", indexer.enabled? ? "border-amber-200 bg-amber-50 text-amber-900" : "border-slate-200 bg-slate-100 text-slate-600") %>">
                  <%= indexer.enabled? ? "Enabled" : "Disabled" %>
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to "Edit", edit_indexer_path(indexer), class: "text-sm font-semibold text-slate-700 hover:text-slate-950" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm font-medium text-slate-700">Add your first Jackett indexer and let Bridgarr tie the stack together.</p>
        <%= link_to "Add your first indexer", new_indexer_path, class: "mt-4 inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      </div>
    <% end %>
  </div>
</div>
