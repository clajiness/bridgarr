<% content_for :title, "Proxy activity" %>

<div class="space-y-6">
  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-950">Proxy activity</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">
        Review Torznab requests Bridgarr has proxied through Jackett, including failures and full error details.
      </p>
    </div>

    <%= link_to "Dashboard", root_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
  </section>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="grid gap-px bg-slate-200 sm:grid-cols-2 lg:grid-cols-5">
      <div class="bg-white px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Requests</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:total] %></p>
      </div>
      <div class="bg-white px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Successful</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:successful] %></p>
      </div>
      <div class="bg-white px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Failed</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:failed] %></p>
      </div>
      <div class="bg-white px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Downloads</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @proxy_activity_stats[:downloads] %></p>
      </div>
      <div class="bg-white px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Avg duration</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= proxy_duration(@proxy_activity_stats[:average_duration_ms]) %></p>
      </div>
    </div>
  </section>

  <section class="rounded-md border border-stone-200 bg-white p-5 shadow-sm">
    <%= form_with url: proxy_activity_path, method: :get, class: "grid gap-4 md:grid-cols-2 xl:grid-cols-[1fr_1fr_1fr_1fr_auto]" do |form| %>
      <div>
        <%= form.label :status, "Status", class: "block text-xs font-semibold uppercase tracking-normal text-slate-500" %>
        <%= form.select :status, options_for_select([ [ "All", "all" ], [ "Failed", "failed" ], [ "Successful", "successful" ] ], @status_filter), {}, class: "mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm" %>
      </div>

      <div>
        <%= form.label :timeframe, "Timeframe", class: "block text-xs font-semibold uppercase tracking-normal text-slate-500" %>
        <%= form.select :timeframe, options_for_select([ [ "Last 24 hours", "24h" ], [ "Last 7 days", "7d" ] ], @timeframe), {}, class: "mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm" %>
      </div>

      <div>
        <%= form.label :indexer_id, "Indexer", class: "block text-xs font-semibold uppercase tracking-normal text-slate-500" %>
        <%= form.select :indexer_id, options_from_collection_for_select(@indexers, :id, :name, @indexer_id), { include_blank: "All indexers" }, class: "mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm" %>
      </div>

      <div>
        <%= form.label :request_type, "Type", class: "block text-xs font-semibold uppercase tracking-normal text-slate-500" %>
        <%= form.select :request_type, options_for_select(@request_types.map { |request_type| [ proxy_request_type_label(request_type), request_type ] }, @request_type), { include_blank: "All types" }, class: "mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm text-slate-950 shadow-sm" %>
      </div>

      <div class="flex items-end gap-3">
        <%= form.submit "Apply", class: "w-full rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400 xl:w-auto" %>
        <%= link_to "Reset", proxy_activity_path, class: "rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
      </div>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Requests</h2>
      <p class="mt-1 text-sm leading-6 text-slate-600">
        Showing <%= pluralize(@proxy_requests.size, "request") %> for the selected filters.
      </p>
    </div>

    <% if @proxy_requests.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
            <tr>
              <th class="px-4 py-3">When</th>
              <th class="px-4 py-3">Indexer</th>
              <th class="px-4 py-3">Type</th>
              <th class="px-4 py-3">Query</th>
              <th class="px-4 py-3">Categories</th>
              <th class="px-4 py-3">Result</th>
              <th class="px-4 py-3 text-right">Duration</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% @proxy_requests.each do |proxy_request| %>
              <tr>
                <td class="whitespace-nowrap px-4 py-3 text-xs text-slate-500"><%= format_utc_timestamp(proxy_request.created_at) %></td>
                <td class="px-4 py-3 font-medium text-slate-950">
                  <% if proxy_request.indexer.present? %>
                    <% indexer_path_for_request = proxy_request.failed? ? indexer_path(proxy_request.indexer, proxy_activity: "failed") : indexer_path(proxy_request.indexer) %>
                    <%= link_to proxy_request.indexer.name, indexer_path_for_request, class: "hover:underline" %>
                  <% else %>
                    <%= proxy_request.jackett_id %>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex rounded-md border border-stone-200 bg-stone-50 px-2 py-1 text-xs font-semibold text-slate-700">
                    <%= proxy_request_type_label(proxy_request.request_type) %>
                  </span>
                </td>
                <td class="px-4 py-3 text-slate-700"><%= proxy_request.query.presence || "None" %></td>
                <td class="px-4 py-3 font-mono text-xs text-slate-600"><%= proxy_request.categories.presence || "None" %></td>
                <td class="px-4 py-3">
                  <div class="space-y-2">
                    <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", proxy_request_status_classes(proxy_request)) %>">
                      <%= proxy_request_status_label(proxy_request) %>
                    </span>
                    <p class="text-xs text-slate-500">
                      HTTP <%= proxy_request.http_status.presence || "n/a" %> · <%= proxy_request_item_count(proxy_request) %>
                    </p>
                    <% if proxy_request.error.present? %>
                      <details class="max-w-2xl rounded-md border border-red-100 bg-red-50 px-3 py-2 text-xs leading-5 text-red-900">
                        <summary class="cursor-pointer font-semibold">Show error</summary>
                        <p class="mt-2 whitespace-pre-wrap break-words"><%= proxy_request.error %></p>
                      </details>
                    <% end %>
                  </div>
                </td>
                <td class="whitespace-nowrap px-4 py-3 text-right text-slate-700"><%= proxy_duration(proxy_request.duration_ms) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm font-medium text-slate-700">No proxy requests match those filters.</p>
      </div>
    <% end %>
  </section>
</div>
