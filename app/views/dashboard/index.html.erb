<% content_for :title, "Dashboard" %>

<div class="space-y-8">
  <section class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-950">Dashboard</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
        Monitor Bridgarr health, sync status, and proxy activity from one place.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= button_to "Sync all", sync_runs_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
      <%= link_to "Add indexer", new_indexer_path, class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
    </div>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-md border border-amber-200/70 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Jackett</p>
      <p class="mt-3 text-2xl font-semibold text-stone-950"><%= @dashboard.jackett_configured? ? "Configured" : "Missing" %></p>
    </div>

    <div class="rounded-md border border-stone-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Apps</p>
      <p class="mt-3 text-2xl font-semibold text-stone-950"><%= @dashboard.enabled_arr_apps_count %> enabled</p>
      <p class="mt-1 text-xs text-slate-500"><%= pluralize(@dashboard.arr_apps_count, "total app") %></p>
    </div>

    <div class="rounded-md border border-stone-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Indexers</p>
      <p class="mt-3 text-2xl font-semibold text-stone-950"><%= @dashboard.enabled_indexers_count %> enabled</p>
      <p class="mt-1 text-xs text-slate-500"><%= pluralize(@dashboard.indexers_count, "total indexer") %></p>
    </div>

    <div class="rounded-md border border-stone-200 bg-white p-5 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Assignments</p>
      <p class="mt-3 text-2xl font-semibold text-stone-950"><%= @dashboard.enabled_assignments_count %> enabled</p>
      <p class="mt-1 text-xs text-slate-500"><%= pluralize(@dashboard.assignments_count, "total assignment") %></p>
    </div>
  </section>

  <section class="<%= class_names("overflow-hidden rounded-md border bg-white shadow-sm", @dashboard.needs_attention? ? "border-red-200" : "border-amber-200/70") %>">
    <div class="flex flex-col gap-3 border-b border-slate-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Health summary</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600"><%= dashboard_attention_summary(@dashboard) %></p>
      </div>
      <% if @dashboard.needs_attention? %>
        <span class="inline-flex w-fit rounded-md border border-red-200 bg-red-50 px-2 py-1 text-xs font-semibold text-red-800">
          Review
        </span>
      <% else %>
        <span class="inline-flex w-fit rounded-md border border-amber-200 bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-900">
          Steady
        </span>
      <% end %>
    </div>

    <div class="grid gap-px bg-slate-200 lg:grid-cols-4">
      <%= link_to sync_runs_path, class: "bg-white px-5 py-4 hover:bg-stone-50" do %>
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Latest sync</p>
        <p class="mt-2 text-xl font-semibold text-slate-950">
          <% if @dashboard.latest_sync_run.present? %>
            <%= sync_run_status_label(@dashboard.latest_sync_run.status) %>
          <% else %>
            None
          <% end %>
        </p>
      <% end %>

      <%= link_to sync_runs_path, class: "bg-white px-5 py-4 hover:bg-stone-50" do %>
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Failed assignments</p>
        <p class="mt-2 text-xl font-semibold text-slate-950"><%= @dashboard.failed_assignments_count %></p>
      <% end %>

      <%= link_to indexers_path, class: "bg-white px-5 py-4 hover:bg-stone-50" do %>
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Not synced</p>
        <p class="mt-2 text-xl font-semibold text-slate-950"><%= @dashboard.unsynced_assignments_count %></p>
      <% end %>

      <%= link_to proxy_activity_path(status: "failed"), class: "bg-white px-5 py-4 hover:bg-stone-50" do %>
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Proxy failures</p>
        <p class="mt-2 text-xl font-semibold text-slate-950"><%= @dashboard.proxy_failures_count %></p>
      <% end %>
    </div>
  </section>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="flex flex-col gap-3 border-b border-slate-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Sync status</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600">Track bulk sync runs as Bridgarr updates managed indexers.</p>
      </div>
      <%= link_to "View sync runs", sync_runs_path, class: "text-sm font-semibold text-slate-700 hover:text-slate-950" %>
    </div>

    <% if @dashboard.latest_sync_run.present? %>
      <div class="grid gap-px bg-slate-200 sm:grid-cols-2 lg:grid-cols-5">
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Status</p>
          <p class="mt-2">
            <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", sync_run_status_classes(@dashboard.latest_sync_run.status)) %>">
              <%= sync_run_status_label(@dashboard.latest_sync_run.status) %>
            </span>
          </p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Assignments</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @dashboard.latest_sync_run.total_count %></p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Succeeded</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @dashboard.latest_sync_run.success_count %></p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Failed</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @dashboard.latest_sync_run.failure_count %></p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Started</p>
          <p class="mt-2 text-sm font-semibold text-slate-700"><%= format_utc_timestamp(@dashboard.latest_sync_run.started_at || @dashboard.latest_sync_run.created_at) %></p>
        </div>
      </div>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-sm font-medium text-slate-700">No sync runs yet.</p>
      </div>
    <% end %>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <div class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Assignment health</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600">Recent failed or unsynced indexer assignments.</p>
      </div>

      <% if @dashboard.failed_assignments.any? || @dashboard.unsynced_assignments.any? %>
        <div class="divide-y divide-slate-200">
          <% (@dashboard.failed_assignments + @dashboard.unsynced_assignments).uniq.first(5).each do |assignment| %>
            <div class="grid gap-3 px-5 py-4 sm:grid-cols-[1fr_auto] sm:items-center">
              <div>
                <p class="font-medium text-slate-950">
                  <%= link_to assignment.indexer.name, assignment.indexer, class: "hover:underline" %>
                  <span class="text-slate-400">&rarr;</span>
                  <%= link_to assignment.arr_app.name, assignment.arr_app, class: "hover:underline" %>
                </p>
                <% if assignment.last_error.present? %>
                  <p class="mt-1 text-xs leading-5 text-red-800"><%= assignment.last_error %></p>
                <% elsif assignment.last_synced_at.present? %>
                  <p class="mt-1 text-xs leading-5 text-slate-500">Last synced <%= format_utc_timestamp(assignment.last_synced_at) %></p>
                <% else %>
                  <p class="mt-1 text-xs leading-5 text-slate-500">Ready for first sync.</p>
                <% end %>
              </div>
              <span class="<%= class_names("inline-flex w-fit rounded-md border px-2 py-1 text-xs font-semibold", assignment_status_classes(assignment)) %>">
                <%= assignment_status_label(assignment) %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-10 text-center">
          <p class="text-sm font-medium text-slate-700">All enabled assignments are synced.</p>
        </div>
      <% end %>
    </div>

    <div class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
      <div class="flex flex-col gap-3 border-b border-slate-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-base font-semibold text-slate-950">Proxy activity</h2>
          <p class="mt-1 text-sm leading-6 text-slate-600">
            Torznab traffic Bridgarr has handled in the last 24 hours.
            <%= @dashboard.showing_proxy_failures? ? "Recent failures are shown for context." : "Showing recent requests." %>
          </p>
        </div>
        <%= link_to "View all activity", proxy_activity_path, class: "text-sm font-semibold text-slate-700 hover:text-slate-950" %>
      </div>

      <div class="grid gap-px bg-slate-200 sm:grid-cols-4">
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Requests</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @dashboard.proxy_activity_stats[:total] %></p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Failed</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @dashboard.proxy_activity_stats[:failed] %></p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Downloads</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @dashboard.proxy_activity_stats[:downloads] %></p>
        </div>
        <div class="bg-white px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Avg duration</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= proxy_duration(@dashboard.proxy_activity_stats[:average_duration_ms]) %></p>
        </div>
      </div>

      <% if @dashboard.visible_proxy_requests.any? %>
        <div class="divide-y divide-slate-200">
          <% @dashboard.visible_proxy_requests.each do |proxy_request| %>
            <div class="grid gap-3 px-5 py-4 sm:grid-cols-[1fr_auto] sm:items-center">
              <div>
                <p class="font-medium text-slate-950">
                  <% if proxy_request.indexer.present? %>
                    <% proxy_request_path = proxy_request.failed? ? proxy_activity_path(status: "failed", indexer_id: proxy_request.indexer_id) : indexer_path(proxy_request.indexer) %>
                    <%= link_to proxy_request.indexer.name, proxy_request_path, class: "hover:underline" %>
                  <% else %>
                    <%= proxy_request.jackett_id %>
                  <% end %>
                </p>
                <p class="mt-1 text-xs leading-5 text-slate-500">
                  <%= proxy_request_type_label(proxy_request.request_type) %>
                  · <%= proxy_request.query.presence || "No query" %>
                  · <%= proxy_duration(proxy_request.duration_ms) %>
                </p>
                <p class="mt-1 text-xs leading-5 text-slate-500">
                  HTTP <%= proxy_request.http_status.presence || "n/a" %>
                  · <%= proxy_request_item_count(proxy_request) %>
                  <% if proxy_request.error.present? && proxy_request.indexer.present? %>
                    · <%= link_to "Open failure details.", proxy_activity_path(status: "failed", indexer_id: proxy_request.indexer_id), class: "font-medium text-red-800 hover:underline" %>
                  <% elsif proxy_request.error.present? %>
                    · Error details are available on the indexer page.
                  <% end %>
                </p>
              </div>
              <span class="<%= class_names("inline-flex w-fit rounded-md border px-2 py-1 text-xs font-semibold", proxy_request_status_classes(proxy_request)) %>">
                <%= proxy_request_status_label(proxy_request) %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-10 text-center">
          <p class="text-sm font-medium text-slate-700">No proxy requests recorded yet.</p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-3">
    <%= link_to arr_apps_path, class: "rounded-md border border-stone-200 bg-white p-5 shadow-sm hover:border-amber-300" do %>
      <h2 class="text-base font-semibold">Apps</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">Add Sonarr, Radarr, Lidarr, and compatible app records.</p>
    <% end %>

    <%= link_to indexers_path, class: "rounded-md border border-stone-200 bg-white p-5 shadow-sm hover:border-amber-300" do %>
      <h2 class="text-base font-semibold">Indexers</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">Track Jackett indexer records and assign them to one or more apps.</p>
    <% end %>

    <%= link_to settings_path, class: "rounded-md border border-stone-200 bg-white p-5 shadow-sm hover:border-amber-300" do %>
      <h2 class="text-base font-semibold">Settings</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">Store the Bridgarr URL plus the Jackett connection used for discovery, proxying, and sync.</p>
    <% end %>
  </section>
</div>
