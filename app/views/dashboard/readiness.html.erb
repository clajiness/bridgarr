<% content_for :title, "Readiness" %>

<div class="space-y-8">
  <section class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-mono text-sm text-slate-500">setup</p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-950">Readiness</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
        Review the setup steps Bridgarr uses before managing and proxying indexers.
      </p>
    </div>

    <%= link_to "Dashboard", root_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
  </section>

  <section class="<%= class_names("overflow-hidden rounded-md border bg-white shadow-sm", @readiness.complete? ? "border-amber-200/70" : "border-stone-200") %>">
    <div class="flex flex-col gap-3 border-b border-slate-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Setup checklist</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600"><%= dashboard_readiness_summary(@readiness) %></p>
      </div>
      <span class="<%= class_names("inline-flex w-fit rounded-md border px-2 py-1 text-xs font-semibold", @readiness.complete? ? "border-amber-200 bg-amber-50 text-amber-900" : "border-slate-200 bg-slate-100 text-slate-700") %>">
        <%= @readiness.complete? ? "Ready" : "Setup" %>
      </span>
    </div>

    <div class="grid gap-px bg-slate-200 lg:grid-cols-2">
      <% @readiness.items.each do |item| %>
        <%= link_to dashboard_readiness_item_path(item), class: "bg-white px-5 py-4 hover:bg-stone-50 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-amber-400" do %>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="font-medium text-slate-950"><%= item.label %></p>
              <p class="mt-1 text-sm leading-6 text-slate-600"><%= item.description %></p>
            </div>
            <span class="<%= class_names("inline-flex w-fit rounded-md border px-2 py-1 text-xs font-semibold", dashboard_readiness_status_classes(item)) %>">
              <%= dashboard_readiness_status_label(item) %>
            </span>
          </div>
          <p class="mt-3 text-sm font-semibold text-slate-700"><%= item.action_label %></p>
        <% end %>
      <% end %>
    </div>
  </section>
</div>
