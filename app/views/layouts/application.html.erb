<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bridgarr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bridgarr">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="<%= asset_path("bridgarr-mark.svg") %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-stone-100 text-slate-950">
    <header class="border-b border-amber-300/20 bg-stone-950">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/brand" %>

        <nav class="flex flex-wrap gap-2 text-sm font-medium">
          <% [
            [ "Dashboard", root_path ],
            [ "Settings", settings_path ],
            [ "Apps", arr_apps_path ],
            [ "Indexers", indexers_path ]
          ].each do |label, path| %>
            <%= link_to label, path, class: class_names(
              "rounded-md px-3 py-2 transition",
              current_page?(path) ? "bg-amber-300 text-stone-950" : "text-stone-300 hover:bg-stone-800 hover:text-amber-100"
            ) %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-5 py-8">
      <% if notice.present? %>
        <p class="mb-6 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-900" id="notice"><%= notice %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
