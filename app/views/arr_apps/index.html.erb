<% content_for :title, "Arr apps" %>

<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-semibold text-slate-950">Apps</h1>
      <p class="mt-2 text-sm leading-6 text-slate-600">Sonarr, Radarr, Lidarr, and compatible app records.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <% if @arr_apps.any? %>
        <%= button_to "Test all", test_connections_arr_apps_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
      <% end %>
      <%= link_to "New app", new_arr_app_path, class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <% if @arr_apps.any? %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Application</th>
            <th class="px-4 py-3">Base URL</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Connection</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @arr_apps.each do |arr_app| %>
            <tr>
              <td class="px-4 py-3 font-medium text-slate-950"><%= link_to arr_app.name, arr_app, class: "hover:underline" %></td>
              <td class="px-4 py-3 text-slate-700"><%= arr_app.app_type.titleize %></td>
              <td class="px-4 py-3 text-slate-700"><%= arr_app.base_url %></td>
              <td class="px-4 py-3">
                <span class="<%= class_names("rounded-md border px-2 py-1 text-xs font-semibold", arr_app.enabled? ? "border-amber-200 bg-amber-50 text-amber-900" : "border-slate-200 bg-slate-100 text-slate-600") %>">
                  <%= arr_app.enabled? ? "Enabled" : "Disabled" %>
                </span>
              </td>
              <td class="px-4 py-3">
                <% if arr_app.last_status.present? %>
                  <div class="min-w-40 space-y-2">
                    <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", arr_app.last_status == "ok" ? "border-amber-200 bg-amber-50 text-amber-900" : "border-red-200 bg-red-50 text-red-800") %>">
                      <%= arr_app.last_status == "ok" ? "Connected" : "Failed" %>
                    </span>
                    <% if arr_app.last_tested_at.present? %>
                      <p class="text-xs leading-5 text-slate-500"><%= format_utc_timestamp(arr_app.last_tested_at) %></p>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-slate-500">Not tested</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap justify-end gap-2">
                  <%= button_to "Test", test_connection_arr_app_path(arr_app), params: { return_to: "index" }, class: "rounded-md border border-stone-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-stone-50" %>
                  <%= link_to "Edit", edit_arr_app_path(arr_app), class: "inline-flex items-center rounded-md px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-stone-50 hover:text-slate-950" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm font-medium text-slate-700">Add Sonarr, Radarr, or friends so Bridgarr knows where to send indexers.</p>
        <%= link_to "Add your first app", new_arr_app_path, class: "mt-4 inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      </div>
    <% end %>
  </div>
</div>
