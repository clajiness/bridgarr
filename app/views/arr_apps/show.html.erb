<% content_for :title, "Showing arr app" %>

<div class="max-w-4xl space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium text-slate-500"><%= @arr_app.app_type.titleize %></p>
      <h1 class="mt-1 text-3xl font-semibold text-slate-950"><%= @arr_app.name %></h1>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= button_to "Test connection", test_connection_arr_app_path(@arr_app), class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      <%= link_to "Edit", edit_arr_app_path(@arr_app), class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
      <%= link_to "Back", arr_apps_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
    </div>
  </div>

  <%= render @arr_app %>

  <section class="overflow-hidden rounded-md border border-stone-200 bg-white shadow-sm">
    <div class="flex flex-col gap-3 border-b border-slate-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Assigned indexers</h2>
        <p class="mt-1 text-sm text-slate-500">Indexers Bridgarr is managing for this app.</p>
      </div>

      <%= link_to "Manage assignments", indexers_path, class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-stone-50" %>
    </div>

    <% if @arr_app.indexer_apps.any? %>
      <table class="min-w-full table-fixed divide-y divide-slate-200 text-sm">
        <thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-normal text-slate-600">
          <tr>
            <th class="w-1/6 px-4 py-3">Indexer</th>
            <th class="w-1/6 px-4 py-3">Jackett ID</th>
            <th class="w-28 px-4 py-3">Connection</th>
            <th class="w-24 px-4 py-3">Remote ID</th>
            <th class="px-4 py-3">Sync status</th>
            <th class="w-44 px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @arr_app.indexer_apps.includes(:indexer).order("indexers.name").each do |assignment| %>
            <% active_sync_run_item = assignment.active_sync_run_item %>
            <tr>
              <td class="px-4 py-3 font-medium text-slate-950"><%= link_to assignment.indexer.name, assignment.indexer, class: "hover:underline" %></td>
              <td class="px-4 py-3 font-mono text-xs text-slate-700"><%= assignment.indexer.jackett_id %></td>
              <td class="px-4 py-3">
                <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", assignment_connection_mode_classes(assignment)) %>">
                  <%= assignment.connection_mode.titleize %>
                </span>
              </td>
              <td class="px-4 py-3 font-mono text-xs text-slate-700"><%= assignment.remote_indexer_id.presence || "None" %></td>
              <td class="min-w-0 px-4 py-3">
                <% if assignment.last_status.present? %>
                  <div class="min-w-0 space-y-2">
                    <span class="<%= class_names("inline-flex rounded-md border px-2 py-1 text-xs font-semibold", assignment_status_classes(assignment)) %>">
                      <%= assignment_status_label(assignment) %>
                    </span>
                    <% if assignment.last_synced_at.present? %>
                      <p class="text-xs leading-5 text-slate-500"><%= format_server_timestamp(assignment.last_synced_at) %></p>
                    <% end %>
                    <% if assignment.last_error.present? %>
                      <p class="<%= class_names("text-xs leading-5 [overflow-wrap:anywhere]", assignment.last_status == "error" ? "text-red-800" : "text-slate-500") %>"><%= assignment_error_summary(assignment) %></p>
                      <details>
                        <summary class="cursor-pointer text-xs font-semibold text-slate-600 hover:text-slate-950">Show technical details</summary>
                        <p class="mt-2 max-h-32 max-w-full overflow-auto whitespace-pre-wrap break-words rounded-md bg-stone-50 p-2 font-mono text-xs leading-5 text-slate-700 [overflow-wrap:anywhere]"><%= assignment.last_error %></p>
                      </details>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-slate-500">Pending sync</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex flex-wrap justify-end gap-2">
                  <%= link_to "Settings", edit_indexer_app_path(assignment, return_to: "arr_app"), class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-stone-50" %>
                  <% if active_sync_run_item.present? %>
                    <%= link_to "View sync", sync_run_path(active_sync_run_item.sync_run), class: "inline-flex items-center justify-center rounded-md border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-semibold text-blue-800 hover:bg-blue-100" %>
                  <% else %>
                    <%= button_to "Sync", sync_indexer_app_path(assignment), params: { return_to: "arr_app" }, class: "rounded-md border border-stone-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-stone-50" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-sm font-medium text-slate-700">No indexers assigned to this app yet.</p>
        <p class="mt-2 text-sm text-slate-500">Assign indexers from an indexer edit page when this app is ready to receive them.</p>
      </div>
    <% end %>
  </section>

  <div class="border-t border-slate-200 pt-6">
    <%= button_to "Remove app", @arr_app, method: :delete, class: "rounded-md bg-red-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-600", data: { turbo_confirm: "Remove this app?" } %>
  </div>
</div>
