<% content_for :title, "Edit assignment" %>

<div class="max-w-3xl space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium text-slate-500"><%= @indexer_app.indexer.name %> to <%= @indexer_app.arr_app.name %></p>
      <h1 class="mt-1 text-3xl font-semibold text-slate-950">Assignment settings</h1>
    </div>

    <%= link_to "Back", params[:return_to] == "arr_app" ? arr_app_path(@indexer_app.arr_app) : indexer_path(@indexer_app.indexer), class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
  </div>

  <%= form_with(model: @indexer_app, class: "space-y-6 rounded-md border border-stone-200 bg-white p-6 shadow-sm") do |form| %>
    <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

    <% if @indexer_app.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
        <p class="font-semibold"><%= pluralize(@indexer_app.errors.count, "error") %> blocked this assignment from being saved.</p>

        <ul class="mt-2 list-disc pl-5">
          <% @indexer_app.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid gap-4 rounded-md border border-stone-200 bg-stone-50 px-4 py-4 sm:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Indexer</p>
        <p class="mt-1 text-sm font-semibold text-slate-950"><%= @indexer_app.indexer.name %></p>
        <p class="mt-1 font-mono text-xs text-slate-500"><%= @indexer_app.indexer.jackett_id %></p>
      </div>

      <div>
        <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">App</p>
        <p class="mt-1 text-sm font-semibold text-slate-950"><%= @indexer_app.arr_app.name %></p>
        <p class="mt-1 text-xs text-slate-500"><%= @indexer_app.arr_app.app_type.titleize %></p>
      </div>
    </div>

    <div>
      <%= form.label :connection_mode, "Connection mode", class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :connection_mode, [["Direct", "direct"], ["Bridged", "bridged"]], {}, class: "mt-2 block w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
      <p class="mt-2 text-xs leading-5 text-slate-500">
        Direct points the app at Jackett. Bridged points the app at Bridgarr so proxy traffic can be recorded.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(0,2fr)]">
      <div>
        <%= form.label :category_mode, "Category mode", class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :category_mode, [["Auto", "auto"], ["Custom", "custom"], ["None", "none"]], {}, class: "mt-2 block w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
      </div>

      <div>
        <%= form.label :custom_categories, "Custom categories", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :custom_categories, placeholder: "2000,2010,8000", class: "mt-2 block w-full rounded-md border border-stone-300 px-3 py-2 font-mono text-sm shadow-sm focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
      </div>
    </div>

    <div class="rounded-md border border-stone-200 bg-stone-50 px-4 py-3 text-xs leading-5 text-slate-600">
      Auto uses the Torznab categories Bridgarr discovers from Jackett for this app type. Custom sends the IDs you enter here. None leaves the category list empty for trackers that need manual handling.
    </div>

    <div class="flex flex-col-reverse gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:justify-end">
      <%= link_to "Cancel", params[:return_to] == "arr_app" ? arr_app_path(@indexer_app.arr_app) : indexer_path(@indexer_app.indexer), class: "inline-flex items-center justify-center rounded-md border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-stone-50" %>
      <%= form.submit "Save assignment", class: "inline-flex items-center justify-center rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-stone-950 shadow-sm hover:bg-amber-400" %>
    </div>
  <% end %>
</div>
